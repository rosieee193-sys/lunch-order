# Admin — quản lý quỹ, đặt món, giải ngân
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT secret (đổi thành chuỗi ngẫu nhiên dài)
JWT_SECRET=your-random-secret-key-here

# Server port
PORT=3001

# Supabase storage (server)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Super Admin Google — email được cấp quyền admin (phân tách bằng dấu phẩy)
SUPER_ADMIN_EMAILS=linhptn@dinogames.gg

# Domain Google Workspace được phép đăng nhập (phân tách bằng dấu phẩy)
ALLOWED_GOOGLE_DOMAINS=dinogames.gg

# Supabase Auth cho frontend (Settings → API → anon public)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
